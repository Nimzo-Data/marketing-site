---
import '../styles/global.css';
import CookieConsent from '../components/ui/CookieConsent.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  structuredData?: object | object[];
}

const {
  title,
  description,
  ogImage = '/images/og-default.png',
  canonicalUrl,
  structuredData,
} = Astro.props;

const canonical = canonicalUrl || Astro.url.href;

// Organization JSON-LD (every page)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Nimzo Data',
  url: 'https://nimzodata.com',
  description:
    'Boutique GCP data consulting — analytics platform builds, optimizations, and ongoing support.',
  email: 'hello@nimzodata.com',
  foundingDate: '2024',
  areaServed: 'Europe',
};

// BreadcrumbList JSON-LD (skip on homepage and 404)
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '/404/';
const breadcrumbLabel = title.replace(/ \| Nimzo Data$/, '');

const breadcrumbSchema = !isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://nimzodata.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: breadcrumbLabel,
          item: canonical,
        },
      ],
    }
  : null;

// Helper to safely serialise JSON-LD (XSS prevention)
function toJsonLd(schema: object): string {
  return JSON.stringify(schema)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}

// Collect all extra structuredData schemas passed via prop
const extraSchemas: object[] = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data: Organization (every page) -->
    <script type="application/ld+json" set:html={toJsonLd(organizationSchema)} />

    <!-- Structured Data: BreadcrumbList (all pages except homepage) -->
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={toJsonLd(breadcrumbSchema)} />
    )}

    <!-- Structured Data: extra schemas from page/layout props -->
    {extraSchemas.map((schema) => (
      <script type="application/ld+json" set:html={toJsonLd(schema)} />
    ))}

    <slot name="head" />
  </head>
  <body>
    <!-- GA4 container — injected after consent -->
    <div id="ga4-container"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
