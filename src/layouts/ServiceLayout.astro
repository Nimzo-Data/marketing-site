---
import BaseLayout from './BaseLayout.astro';
import HeroStandard from '../components/heroes/HeroStandard.astro';
import CTACard from '../components/cards/CTACard.astro';
import CTABanner from '../components/cards/CTABanner.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, heroTitle, heroSubtitle, ogImage, canonicalUrl } = Astro.props;

// Strip " | Nimzo Data" suffix to get the bare service name
const serviceName = title.replace(/ \| Nimzo Data$/, '');

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'Organization',
    name: 'Nimzo Data',
  },
  name: serviceName,
  description,
  areaServed: 'Europe',
  serviceType: 'Data Consulting',
};
---

<BaseLayout {title} {description} {ogImage} {canonicalUrl} structuredData={serviceSchema}>
  <HeroStandard title={heroTitle} subtitle={heroSubtitle} />
  <slot />
  <SectionWrapper py="lg">
    <CTACard
      title="Need ongoing support?"
      description="After implementation, keep your platform healthy with a monthly retainer."
      href="/services/ongoing-support-retainers/"
    />
  </SectionWrapper>
  <CTABanner
    heading="Ready to talk about your data stack?"
    buttonText="Book a free call"
    buttonHref="/contact/"
    dataTrack="service-layout-cta"
  />
</BaseLayout>
