---
interface Props {
  url?: string;
  minHeight?: string;
}

const {
  url = 'https://calendly.com/nimzodata/free-call',
  minHeight = '630px',
} = Astro.props;
---

<div class="calendly-wrapper" style={`min-height:${minHeight}`}>
  <div
    class="calendly-inline-widget"
    data-url={url}
    style={`min-width:320px;min-height:${minHeight}`}
  ></div>
  <div class="calendly-skeleton" aria-hidden="true">
    <div class="calendly-skeleton-inner">
      <div class="skel-line skel-line--sm"></div>
      <div class="skel-line skel-line--lg"></div>
      <div class="skel-grid">
        <div class="skel-cell"></div><div class="skel-cell"></div><div class="skel-cell"></div>
        <div class="skel-cell"></div><div class="skel-cell"></div><div class="skel-cell"></div>
        <div class="skel-cell"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .calendly-wrapper {
    position: relative;
    min-width: 320px;
  }
  .calendly-inline-widget {
    position: relative;
    z-index: 2;
  }
  .calendly-skeleton {
    position: absolute;
    inset: 0;
    background: var(--color-card);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .calendly-skeleton-inner {
    width: min(80%, 420px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .skel-line {
    height: 18px;
    border-radius: 4px;
    background: linear-gradient(90deg, rgba(0,79,76,0.08), rgba(0,79,76,0.16), rgba(0,79,76,0.08));
    background-size: 200% 100%;
    animation: skel-shimmer 1.6s ease-in-out infinite;
  }
  .skel-line--sm { width: 40%; }
  .skel-line--lg { width: 75%; height: 28px; }
  .skel-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    margin-top: 8px;
  }
  .skel-cell {
    aspect-ratio: 1;
    border-radius: 4px;
    background: linear-gradient(90deg, rgba(0,79,76,0.06), rgba(0,79,76,0.14), rgba(0,79,76,0.06));
    background-size: 200% 100%;
    animation: skel-shimmer 1.6s ease-in-out infinite;
  }
  @keyframes skel-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .skel-line, .skel-cell { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    if (!document.querySelector('script[src*="calendly.com/assets/external/widget.js"]')) {
      var script = document.createElement('script');
      script.src = 'https://assets.calendly.com/assets/external/widget.js';
      script.async = true;
      document.head.appendChild(script);
    }
  })();
</script>
