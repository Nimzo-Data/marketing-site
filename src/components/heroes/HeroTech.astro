---
interface Props {
  toolName: string;
  toolLogo?: string;
  toolCategory: string;
  positioning: string;
}

const { toolName, toolLogo, toolCategory, positioning } = Astro.props;
---

<section class="hero-tech">
  <div class="hero-inner">
    <div class="hero-logo-area">
      {toolLogo ? (
        <img src={toolLogo} alt={`${toolName} logo`} class="tool-logo" width="64" height="64" loading="eager" />
      ) : (
        <div class="tool-logo-placeholder" aria-hidden="true">
          {toolName.slice(0, 2).toUpperCase()}
        </div>
      )}
    </div>
    <span class="category-badge">{toolCategory}</span>
    <h1 class="hero-title">{toolName}</h1>
    <p class="hero-positioning">{positioning}</p>
  </div>
</section>

<style>
  .hero-tech {
    width: 100%;
    background-color: var(--color-white);
    padding-top: clamp(80px, 10vw, 128px);
    padding-bottom: clamp(64px, 8vw, 96px);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: left;
  }

  @media (min-width: 768px) {
    .hero-inner {
      padding: 0 48px;
    }
  }

  .hero-logo-area {
    margin-bottom: 16px;
  }

  .tool-logo {
    display: block;
    width: 64px;
    height: 64px;
    object-fit: contain;
    border-radius: 8px;
  }

  .tool-logo-placeholder {
    width: 64px;
    height: 64px;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
  }

  .category-badge {
    display: inline-block;
    background-color: transparent;
    color: var(--color-brand-plum);
    border: 1px solid var(--color-brand-plum);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    font-size: 2rem;
    line-height: 1.2;
    margin: 0 0 20px 0;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 2.75rem;
    }
  }

  .hero-positioning {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.55;
    max-width: 720px;
    text-wrap: balance;
  }
</style>
