---
import Button from '../ui/Button.astro';
import { navItems, ctaLink } from '../../data/navigation';
---

<!-- Overlay backdrop -->
<div
  id="mobile-overlay"
  class="mobile-overlay"
  aria-hidden="true"
></div>

<!-- Mobile slide-out panel -->
<div
  id="mobile-menu"
  class="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <!-- Menu header -->
  <div class="mobile-menu-header">
    <span class="mobile-logo">Nimzo Data</span>
    <button
      id="mobile-close-btn"
      class="mobile-close"
      aria-label="Close navigation menu"
      type="button"
    >
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav aria-label="Mobile navigation" class="mobile-nav">
    <ul class="mobile-nav-list" role="list">
      {navItems.map((item) => (
        <li class="mobile-nav-section">
          {item.type === 'link' ? (
            <a href={item.href} class="mobile-nav-link mobile-nav-link--top">
              {item.label}
            </a>
          ) : (
            <>
              {item.href ? (
                <a href={item.href} class="mobile-nav-link mobile-nav-link--top">{item.label}</a>
              ) : (
                <p class="mobile-section-label">{item.label}</p>
              )}
              {item.groups.map((group) => (
                <div class="mobile-group">
                  {group.groupLabel && (
                    <p class="mobile-group-label">{group.groupLabel}</p>
                  )}
                  <ul role="list" class="mobile-sub-list">
                    {group.links.map((link) => (
                      <li>
                        <a href={link.href} class="mobile-nav-link">
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <!-- CTA at bottom -->
  <div class="mobile-cta">
    <Button href={ctaLink.href} variant="primary" size="md" class="mobile-cta-btn">
      {ctaLink.label}
    </Button>
  </div>
</div>

<script>
  import { createFocusTrap } from 'focus-trap';

  const hamburger = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
  const closeBtn = document.getElementById('mobile-close-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const overlay = document.getElementById('mobile-overlay') as HTMLElement | null;

  if (!hamburger || !closeBtn || !menu || !overlay) {
    console.warn('MobileMenu: required elements not found');
  } else {
    const trap = createFocusTrap(menu, {
      onActivate() {
        menu.setAttribute('aria-hidden', 'false');
      },
      onDeactivate() {
        menu.setAttribute('aria-hidden', 'true');
      },
      initialFocus: closeBtn,
      returnFocusOnDeactivate: false,
    });

    function openMenu() {
      document.body.style.overflow = 'hidden';
      menu!.classList.add('is-open');
      overlay!.classList.add('is-visible');
      hamburger!.setAttribute('aria-expanded', 'true');
      menu!.setAttribute('aria-hidden', 'false');
      trap.activate();
    }

    function closeMenu() {
      trap.deactivate();
      menu!.classList.remove('is-open');
      overlay!.classList.remove('is-visible');
      hamburger!.setAttribute('aria-expanded', 'false');
      menu!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      hamburger!.focus();
    }

    hamburger.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && menu!.classList.contains('is-open')) {
        closeMenu();
      }
    });

    // Close on nav link click (navigating away)
    menu.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Close menu when resizing to desktop to unlock body scroll
    const mql = window.matchMedia('(min-width: 1024px)');
    mql.addEventListener('change', (e) => {
      if (e.matches && menu.classList.contains('is-open')) {
        closeMenu();
      }
    });
  }
</script>

<style>
  /* Overlay backdrop */
  .mobile-overlay {
    display: block;
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 149;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .mobile-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 1024px) {
    .mobile-overlay {
      display: none;
    }
  }

  /* Mobile menu panel */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 90vw);
    background-color: var(--color-white);
    z-index: 150;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 200ms ease;
    overflow-y: auto;
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
    }
  }

  /* Menu header row */
  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    height: 64px;
    flex-shrink: 0;
  }

  .mobile-logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-primary);
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 6px;
    color: var(--color-text);
    padding: 0;
  }

  .mobile-close:hover {
    background-color: var(--color-surface-hover);
  }

  /* Nav content */
  .mobile-nav {
    flex: 1;
    overflow-y: auto;
    padding: 16px 0;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-section {
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav-section:last-child {
    border-bottom: none;
  }

  .mobile-section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 4px 0;
    padding: 4px 20px;
  }

  .mobile-group {
    margin-bottom: 8px;
  }

  .mobile-group-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 8px 0 2px 0;
    padding: 0 20px 0 32px;
  }

  .mobile-sub-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 10px 20px;
    font-size: 15px;
    color: var(--color-text);
    text-decoration: none;
    transition: color 150ms ease, background-color 150ms ease;
  }

  .mobile-nav-link--top {
    font-weight: 500;
    font-size: 16px;
    color: var(--color-primary);
  }

  .mobile-sub-list .mobile-nav-link {
    padding-left: 32px;
    font-size: 14px;
  }

  .mobile-nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-surface-hover);
  }

  /* Bottom CTA */
  .mobile-cta {
    padding: 20px;
    border-top: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .mobile-cta-btn {
    width: 100%;
    text-align: center;
    justify-content: center;
  }
</style>
