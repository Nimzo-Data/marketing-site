---
import { serviceLinks, technologyGroups, companyLinks } from '../../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <!-- Main columns -->
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div class="footer-col footer-col--brand">
        <p class="footer-logo">Nimzo Data</p>
        <p class="footer-tagline">
          Boutique GCP data consulting for European companies.
        </p>
        <p class="footer-location">Based in France · Serving Europe</p>
      </div>

      <!-- Column 2: Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links" role="list">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Technology -->
      <div class="footer-col">
        <h4 class="footer-heading">Technology</h4>
        <div class="footer-tech-groups">
          {technologyGroups.map((group) => (
            <div class="footer-tech-group">
              <p class="footer-tech-category">{group.category}</p>
              <ul class="footer-links" role="list">
                {group.links.map((link) => (
                  <li>
                    <a href={link.href} class="footer-link">{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Column 4: Company -->
      <div class="footer-col">
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-links" role="list">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {currentYear} Nimzo Data. All rights reserved.
      </p>
      <ul class="footer-bottom-links" role="list">
        <li><a href="/privacy-policy/" class="footer-bottom-link">Privacy Policy</a></li>
        <li><a href="/terms-of-service/" class="footer-bottom-link">Terms of Service</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 24px 32px;
  }

  @media (min-width: 768px) {
    .footer-inner {
      padding: 64px 48px 32px;
    }
  }

  /* 4-column grid on desktop */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  /* 2-col on tablet */
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px 32px;
    }
  }

  /* 4-col on desktop */
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 48px;
    }
  }

  /* Brand column */
  .footer-logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 22px;
    color: var(--color-white);
    margin: 0 0 12px 0;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    margin: 0 0 8px 0;
  }

  .footer-location {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  /* Column headings */
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 16px 0;
  }

  /* Links */
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 150ms ease;
    line-height: 1.4;
  }

  .footer-link:hover {
    color: var(--color-white);
  }

  /* Technology grouped column */
  .footer-tech-groups {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer-tech-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-tech-category {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-copy {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .footer-bottom-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 20px;
  }

  .footer-bottom-link {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .footer-bottom-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }
</style>
