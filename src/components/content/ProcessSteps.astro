---
interface Step {
  number: number;
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="process-steps">
  {steps.map((step, index) => (
    <div class="step-wrapper">
      <div class="step">
        <div class="step-number" aria-label={`Step ${step.number}`}>
          {step.number}
        </div>
        <div class="step-content">
          <h3 class="step-title">{step.title}</h3>
          <p class="step-description">{step.description}</p>
        </div>
      </div>
      {index < steps.length - 1 && (
        <div class="step-connector" aria-hidden="true" />
      )}
    </div>
  ))}
</div>

<style>
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (min-width: 768px) {
    .process-steps {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .step-wrapper {
    display: contents;
  }

  @media (min-width: 768px) {
    .step-wrapper {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      flex: 1;
    }
  }

  .step {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
    padding: 0 0 32px 0;
    position: relative;
  }

  @media (min-width: 768px) {
    .step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0;
      flex: 1;
    }
  }

  /* Vertical connector line on mobile */
  .step::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 44px;
    width: 2px;
    height: calc(100% - 44px);
    background-color: var(--color-card);
  }

  @media (min-width: 768px) {
    .step::before {
      display: none;
    }
  }

  .step-number {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    position: relative;
    z-index: 1;
  }

  .step-content {
    flex: 1;
  }

  @media (min-width: 768px) {
    .step-content {
      flex: none;
      width: 100%;
    }
  }

  .step-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-primary);
    margin: 0 0 6px 0;
  }

  @media (min-width: 768px) {
    .step-title {
      margin-top: 12px;
    }
  }

  .step-description {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  /* Horizontal connector between steps on desktop */
  .step-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .step-connector {
      display: block;
      flex-shrink: 0;
      width: 40px;
      height: 2px;
      background-color: var(--color-card);
      margin-top: 19px; /* align with center of 40px number circle */
    }
  }
</style>
