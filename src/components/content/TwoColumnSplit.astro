---
interface Props {
  leftTitle: string;
  leftItems: string[];
  rightTitle: string;
  rightItems: string[];
  variant?: 'challenges-solution' | 'is-for';
}

const {
  leftTitle,
  leftItems,
  rightTitle,
  rightItems,
  variant = 'challenges-solution',
} = Astro.props;

// challenges-solution: left = X (red), right = checkmark (green)
// is-for: left = checkmark (green), right = X (red)
const leftIsCheck = variant === 'is-for';
const rightIsCheck = variant === 'challenges-solution';
---

<div class="two-col-split">
  <div class="col col-left">
    <h3 class="col-title">{leftTitle}</h3>
    <ul class="item-list">
      {leftItems.map((item) => (
        <li class="item-row">
          {leftIsCheck ? (
            <span class="icon icon-check" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="var(--color-success)" fill-opacity="0.12"/>
                <path d="M5 9.5L7.5 12L13 7" stroke="var(--color-success)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          ) : (
            <span class="icon icon-x" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="var(--color-error)" fill-opacity="0.12"/>
                <path d="M6 6L12 12M12 6L6 12" stroke="var(--color-error)" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
          )}
          <span class="item-text">{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="col col-right">
    <h3 class="col-title">{rightTitle}</h3>
    <ul class="item-list">
      {rightItems.map((item) => (
        <li class="item-row">
          {rightIsCheck ? (
            <span class="icon icon-check" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="var(--color-success)" fill-opacity="0.12"/>
                <path d="M5 9.5L7.5 12L13 7" stroke="var(--color-success)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          ) : (
            <span class="icon icon-x" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="var(--color-error)" fill-opacity="0.12"/>
                <path d="M6 6L12 12M12 6L6 12" stroke="var(--color-error)" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
          )}
          <span class="item-text">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .two-col-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .two-col-split {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  .col {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
  }

  .col-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 20px 0;
  }

  .item-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .item-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    margin-top: 2px;
  }

  .item-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
  }
</style>
