---
interface Props {
  leftTitle: string;
  leftItems: string[];
  rightTitle: string;
  rightItems: string[];
  variant?: 'challenges-solution' | 'is-for';
  bare?: boolean;
}

const {
  leftTitle,
  leftItems,
  rightTitle,
  rightItems,
  variant = 'challenges-solution',
  bare = false,
} = Astro.props;

// challenges-solution: LEFT plum cross (problems), RIGHT teal tick (solutions)
// is-for: LEFT teal tick, RIGHT plum cross
const leftIcon: 'tick' | 'cross' = variant === 'is-for' ? 'tick' : 'cross';
const rightIcon: 'tick' | 'cross' = variant === 'is-for' ? 'cross' : 'tick';
---

<div class={`two-col-split${bare ? ' two-col-split--bare' : ''}`}>
  <div class={`col col-left col--${variant}-left`}>
    <h3 class="col-title">{leftTitle}</h3>
    <ul class="item-list">
      {leftItems.map((item) => (
        <li class="item-row">
          {leftIcon === 'tick' && (
            <span class="icon icon-tick" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="#004f4c" fill-opacity="0.12"/>
                <path d="M5 9.5L7.5 12L13 7" stroke="#004f4c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          )}
          {leftIcon === 'cross' && (
            <span class="icon icon-cross" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="#493441" fill-opacity="0.14"/>
                <path d="M6 6L12 12M12 6L6 12" stroke="#493441" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
          )}
          {leftIcon === 'none' && (
            <span class="icon icon-bullet" aria-hidden="true"></span>
          )}
          <span class="item-text">{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class={`col col-right col--${variant}-right`}>
    <h3 class="col-title">{rightTitle}</h3>
    <ul class="item-list">
      {rightItems.map((item) => (
        <li class="item-row">
          {rightIcon === 'tick' ? (
            <span class="icon icon-tick" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="#004f4c" fill-opacity="0.12"/>
                <path d="M5 9.5L7.5 12L13 7" stroke="#004f4c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          ) : (
            <span class="icon icon-cross" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="9" fill="#493441" fill-opacity="0.14"/>
                <path d="M6 6L12 12M12 6L6 12" stroke="#493441" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
          )}
          <span class="item-text">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .two-col-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .two-col-split {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  .col {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-card);
  }

  /* Bare variant: no card wrapper, vertical divider between columns on desktop */
  .two-col-split--bare .col {
    background-color: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    border-radius: 0;
  }

  @media (min-width: 768px) {
    .two-col-split--bare {
      gap: 48px;
    }

    .two-col-split--bare .col-right {
      border-left: 1px solid var(--color-border-subtle);
      padding-left: 48px;
    }
  }

  .col-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 20px 0;
  }

  .col--challenges-solution-right .col-title {
    color: var(--color-primary);
  }

  .item-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .item-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    margin-top: 2px;
    width: 18px;
    height: 18px;
  }

  .icon-bullet {
    position: relative;
  }

  .icon-bullet::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-text-secondary);
  }

  .item-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
  }
</style>
