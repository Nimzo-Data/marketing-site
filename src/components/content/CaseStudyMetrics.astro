---
type IconName =
  | 'zap'
  | 'clock'
  | 'trending-down'
  | 'database'
  | 'bar-chart'
  | 'shield-check'
  | 'calendar';

interface Metric {
  icon: IconName;
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class={`cs-metrics cs-metrics--cols-${Math.min(metrics.length, 4)}`}>
  {metrics.map((m) => (
    <div class="cs-metrics__item">
      <span class="cs-metrics__icon" aria-hidden="true">
        {m.icon === 'zap' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
          </svg>
        )}
        {m.icon === 'clock' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <polyline points="12 7 12 12 15 14"/>
          </svg>
        )}
        {m.icon === 'trending-down' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/>
            <polyline points="16 17 22 17 22 11"/>
          </svg>
        )}
        {m.icon === 'database' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
            <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
          </svg>
        )}
        {m.icon === 'bar-chart' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="20" x2="4" y2="12"/>
            <line x1="10" y1="20" x2="10" y2="6"/>
            <line x1="16" y1="20" x2="16" y2="14"/>
            <line x1="22" y1="20" x2="22" y2="9"/>
          </svg>
        )}
        {m.icon === 'shield-check' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        )}
        {m.icon === 'calendar' && (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="16" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="8" y1="3" x2="8" y2="7"/>
            <line x1="16" y1="3" x2="16" y2="7"/>
          </svg>
        )}
      </span>
      <p class="cs-metrics__value">{m.value}</p>
      <p class="cs-metrics__label">{m.label}</p>
    </div>
  ))}
</div>

<style>
  .cs-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 0;
  }

  @media (min-width: 768px) {
    .cs-metrics--cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .cs-metrics--cols-4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cs-metrics__item {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0 20px;
    border-left: 1px solid var(--color-border-subtle);
  }

  .cs-metrics__item:first-child {
    border-left: none;
    padding-left: 0;
  }

  /* Mobile: 2-col, every 1st column has no left border */
  @media (max-width: 767px) {
    .cs-metrics__item {
      padding: 0 16px;
    }
    .cs-metrics__item:nth-child(odd) {
      border-left: none;
      padding-left: 0;
    }
  }

  .cs-metrics__icon {
    display: inline-flex;
    color: var(--color-brand-teal);
    margin-bottom: 2px;
  }

  .cs-metrics__value {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-brand-teal);
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.005em;
  }

  .cs-metrics__label {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
</style>
