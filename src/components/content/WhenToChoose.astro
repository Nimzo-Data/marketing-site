---
interface Block {
  heading: string;
  bullets: string[];
  note?: string;
}

interface Props {
  title: string;
  intro?: string;
  blocks: Block[];
  footer?: string;
}

const { title, intro, blocks, footer } = Astro.props;
const gridClass = `wtc-grid wtc-grid--${blocks.length}`;
---

<div class="wtc">
  <h2 class="wtc-title">{title}</h2>
  {intro && <p class="wtc-intro">{intro}</p>}

  <div class={gridClass}>
    {blocks.map((b) => (
      <div class="wtc-card">
        <h3 class="wtc-card-heading">{b.heading}</h3>
        <ul class="wtc-list">
          {b.bullets.map((item) => (<li>{item}</li>))}
        </ul>
        {b.note && <p class="wtc-note">{b.note}</p>}
      </div>
    ))}
  </div>

  {footer && <p class="wtc-footer">{footer}</p>}
</div>

<style>
  .wtc-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .wtc-intro {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: -16px 0 32px 0;
    max-width: 720px;
  }

  .wtc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .wtc-grid {
      gap: 20px;
    }
  }

  @media (min-width: 768px) {
    .wtc-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .wtc-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .wtc-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .wtc-grid--4 { grid-template-columns: repeat(4, 1fr); }
  }

  .wtc-card {
    background-color: var(--color-bg-default);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wtc-card-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .wtc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .wtc-list li {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.55;
  }

  .wtc-list li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 9px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-brand-plum);
  }

  .wtc-note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin: 4px 0 0 0;
    line-height: 1.6;
  }

  .wtc-footer {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 24px 0 0 0;
    max-width: 820px;
  }
</style>
