---
import type { RetainerTier, RetainerRow } from '../../data/retainers';

interface Props {
  tiers: RetainerTier[];
  rows: RetainerRow[];
}

const { tiers, rows } = Astro.props;

const tierKeys: Array<'maintenance' | 'growth' | 'partnership'> = ['maintenance', 'growth', 'partnership'];

function cellContent(value: string | boolean) {
  if (typeof value === 'string') return { kind: 'text' as const, text: value };
  return { kind: value ? 'yes' as const : 'no' as const };
}
---

<!-- Desktop comparison table -->
<div class="rt-desktop">
  <table class="rt-table">
    <thead>
      <tr>
        <th class="rt-th rt-th--label" aria-hidden="true"></th>
        {tiers.map((tier) => (
          <th class={`rt-th ${tier.highlighted ? 'rt-th--highlighted' : ''}`}>
            <div class="rt-th-name">{tier.name}</div>
            <div class="rt-th-sub">{tier.subtitle}</div>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      <tr class="rt-price-row">
        <td class="rt-td rt-td--label">Price</td>
        {tiers.map((tier) => (
          <td class={`rt-td rt-td--price ${tier.highlighted ? 'rt-td--highlighted' : ''}`}>{tier.price}</td>
        ))}
      </tr>
      <tr>
        <td class="rt-td rt-td--label">Hours included</td>
        {tiers.map((tier) => (
          <td class={`rt-td ${tier.highlighted ? 'rt-td--highlighted' : ''}`}>{tier.hours}</td>
        ))}
      </tr>

      {rows.map((row) => (
        <tr>
          <td class="rt-td rt-td--label">{row.label}</td>
          {tierKeys.map((k) => {
            const c = cellContent(row[k]);
            const tier = tiers.find((t) => t.name.toLowerCase() === k)!;
            return (
              <td class={`rt-td ${tier.highlighted ? 'rt-td--highlighted' : ''}`}>
                {c.kind === 'yes' && (
                  <span class="rt-tick" aria-label="included">
                    <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
                      <circle cx="9" cy="9" r="9" fill="#004f4c" fill-opacity="0.12"/>
                      <path d="M5 9.5L7.5 12L13 7" stroke="#004f4c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    </svg>
                  </span>
                )}
                {c.kind === 'no' && (<span class="rt-dash" aria-label="not included">—</span>)}
                {c.kind === 'text' && (<span>{c.text}</span>)}
              </td>
            );
          })}
        </tr>
      ))}

      <tr>
        <td class="rt-td rt-td--label">Response time</td>
        {tiers.map((tier) => (
          <td class={`rt-td ${tier.highlighted ? 'rt-td--highlighted' : ''}`}>{tier.responseTime}</td>
        ))}
      </tr>
      <tr>
        <td class="rt-td rt-td--label">Check-ins</td>
        {tiers.map((tier) => (
          <td class={`rt-td ${tier.highlighted ? 'rt-td--highlighted' : ''}`}>{tier.checkInFrequency}</td>
        ))}
      </tr>
    </tbody>
  </table>
</div>

<!-- Mobile stacked tier cards -->
<div class="rt-mobile">
  {tiers.map((tier) => (
    <div class={`rt-card ${tier.highlighted ? 'rt-card--highlighted' : ''}`}>
      <div class="rt-card-head">
        <h3 class="rt-card-name">{tier.name}</h3>
        <p class="rt-card-sub">{tier.subtitle}</p>
        <div class="rt-card-price">{tier.price}</div>
        <div class="rt-card-hours">{tier.hours} included</div>
      </div>

      <ul class="rt-card-list">
        {rows
          .filter((row) => row[tier.name.toLowerCase() as 'maintenance' | 'growth' | 'partnership'] === true)
          .map((row) => (
            <li class="rt-card-row">
              <span class="rt-tick" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 18 18"><circle cx="9" cy="9" r="9" fill="#004f4c" fill-opacity="0.12"/><path d="M5 9.5L7.5 12L13 7" stroke="#004f4c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
              </span>
              <span>{row.label}</span>
            </li>
          ))}
      </ul>

      <div class="rt-card-meta">
        <div class="rt-card-meta-row"><span>Response time</span><strong>{tier.responseTime}</strong></div>
        <div class="rt-card-meta-row"><span>Check-ins</span><strong>{tier.checkInFrequency}</strong></div>
      </div>
    </div>
  ))}
</div>

<style>
  /* Desktop: show table from md+ */
  .rt-desktop { display: none; }
  .rt-mobile { display: grid; grid-template-columns: 1fr; gap: 20px; }

  @media (min-width: 900px) {
    .rt-desktop { display: block; overflow-x: auto; }
    .rt-mobile { display: none; }
  }

  .rt-table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-card);
  }

  .rt-th {
    padding: 20px 16px;
    text-align: left;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-card);
    vertical-align: bottom;
  }

  .rt-th--label {
    width: 30%;
  }

  .rt-th--highlighted {
    border: 1px solid var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
    background-color: rgba(73, 52, 65, 0.04);
  }

  .rt-th-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-bottom: 4px;
  }

  .rt-th-sub {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .rt-td {
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-card);
  }

  .rt-td--label {
    font-weight: 500;
    color: var(--color-primary);
  }

  .rt-td--highlighted {
    background-color: rgba(73, 52, 65, 0.04);
    border-left: 1px solid var(--color-accent);
    border-right: 1px solid var(--color-accent);
  }

  .rt-price-row .rt-td {
    background-color: var(--color-surface-subtle);
  }

  .rt-td--price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-brand-plum);
  }

  .rt-tick { display: inline-flex; vertical-align: middle; }
  .rt-dash { color: var(--color-text-secondary); }

  /* Mobile cards */
  .rt-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .rt-card--highlighted {
    border: 2px solid var(--color-accent);
  }

  .rt-card-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 0;
  }

  .rt-card-sub {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 2px 0 0 0;
  }

  .rt-card-price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.375rem;
    color: var(--color-brand-plum);
    margin-top: 8px;
  }

  .rt-card-hours {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .rt-card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rt-card-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .rt-card-meta {
    border-top: 1px solid var(--color-card);
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rt-card-meta-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .rt-card-meta-row strong {
    color: var(--color-primary);
    font-weight: 500;
  }
</style>
