---
interface Props {
  title: string;
  priceRange: string;
  timeline?: string;
  details: string[];
  href?: string;
}

const { title, priceRange, timeline, details } = Astro.props;
---

<article class="service-card-small">
  <div class="card-header">
    <h3 class="card-title">{title}</h3>
    <div class="card-badges">
      <span class="badge badge-price">{priceRange}</span>
      {timeline && <span class="badge badge-timeline">{timeline}</span>}
    </div>
  </div>
  {details.length > 0 && (
    <ul class="card-details">
      {details.map((detail) => (
        <li class="detail-item">{detail}</li>
      ))}
    </ul>
  )}
</article>

<style>
  .service-card-small {
    background-color: var(--color-bg-default);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1.0625rem;
    margin: 0;
    line-height: 1.3;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 100px;
    line-height: 1.4;
    background-color: transparent;
    color: var(--color-brand-plum);
    border: 1px solid var(--color-brand-plum);
  }

  .card-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .detail-item {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .detail-item::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }
</style>
