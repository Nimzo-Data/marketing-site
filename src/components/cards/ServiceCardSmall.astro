---
interface Props {
  title: string;
  priceRange: string;
  timeline?: string;
  details: string[];
  href: string;
}

const { title, priceRange, timeline, details, href } = Astro.props;
---

<article class="service-card-small">
  <div class="card-header">
    <h3 class="card-title">{title}</h3>
    <div class="card-meta">
      <span class="meta-price">{priceRange}</span>
      {timeline && <span class="meta-separator">&middot;</span>}
      {timeline && <span class="meta-timeline">{timeline}</span>}
    </div>
  </div>
  {details.length > 0 && (
    <ul class="card-details">
      {details.map((detail) => (
        <li class="detail-item">{detail}</li>
      ))}
    </ul>
  )}
  <a href={href} class="card-link">Learn more &rarr;</a>
</article>

<style>
  .service-card-small {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1rem;
    margin: 0;
    line-height: 1.3;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-price {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .meta-separator {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .meta-timeline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .card-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .detail-item {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .detail-item::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  .card-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    display: inline-block;
    margin-top: auto;
  }

  .card-link:hover {
    text-decoration: underline;
  }
</style>
