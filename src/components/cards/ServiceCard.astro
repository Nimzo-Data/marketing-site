---
interface Props {
  title: string;
  description: string;
  priceRange?: string;
  timeline?: string;
  href: string;
  dataTrack?: string;
}

const { title, description, priceRange, timeline, href, dataTrack } = Astro.props;
---

<article class="service-card">
  <div class="card-icon" aria-hidden="true"></div>
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
  {(priceRange || timeline) && (
    <div class="card-badges">
      {priceRange && <span class="badge badge-price">{priceRange}</span>}
      {timeline && <span class="badge badge-timeline">{timeline}</span>}
    </div>
  )}
  <a href={href} class="card-link" data-track={dataTrack}>
    Learn more &rarr;
  </a>
</article>

<style>
  .service-card {
    background-color: var(--color-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background-color: var(--color-primary);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1.125rem;
    margin: 0;
    line-height: 1.3;
  }

  .card-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 100px;
    line-height: 1.4;
  }

  .badge-price {
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .badge-timeline {
    background-color: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }

  .card-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    display: inline-block;
    margin-top: auto;
  }

  .card-link:hover {
    text-decoration: underline;
  }
</style>
