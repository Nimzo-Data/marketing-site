---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  priceRange?: string;
  timeline?: string;
  href: string;
  dataTrack?: string;
  linkText?: string;
}

const {
  eyebrow,
  title,
  description,
  priceRange,
  timeline,
  href,
  dataTrack,
  linkText = 'Learn more',
} = Astro.props;
---

<a href={href} class="service-card" data-track={dataTrack}>
  <p class="card-eyebrow">{eyebrow}</p>
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
  {(priceRange || timeline) && (
    <div class="card-badges">
      {priceRange && <span class="badge badge-price">{priceRange}</span>}
      {timeline && <span class="badge badge-timeline">{timeline}</span>}
    </div>
  )}
  <span class="card-link">{linkText} <span class="card-arrow" aria-hidden="true">&rarr;</span></span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    padding: 32px;
    background-color: var(--color-bg-default);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 150ms ease, transform 150ms ease, border-color 150ms ease;
  }

  .service-card:hover {
    box-shadow: var(--shadow-dropdown);
    transform: translateY(-2px);
    border-color: var(--color-brand-plum);
  }

  .card-eyebrow {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-plum);
    margin: 0;
    line-height: 1.2;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1.25rem;
    margin: 0;
    margin-top: -4px;
    line-height: 1.3;
  }

  .card-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.65;
    flex: 1;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 100px;
    line-height: 1.4;
    background-color: transparent;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .badge-price {
    color: var(--color-brand-plum);
    border: 1px solid var(--color-brand-plum);
  }

  .badge-timeline {
    color: var(--color-brand-plum);
    border: 1px solid var(--color-brand-plum);
  }

  .service-card:hover .badge {
    background-color: var(--color-brand-plum);
    color: var(--color-text-on-dark);
  }

  .card-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-top: auto;
  }

  .card-arrow {
    display: inline-block;
    transition: transform 150ms ease;
  }

  .service-card:hover .card-link {
    text-decoration: underline;
  }

  .service-card:hover .card-arrow {
    transform: translateX(4px);
  }
</style>
