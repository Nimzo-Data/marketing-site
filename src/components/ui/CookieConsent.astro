---
// CookieConsent.astro — GDPR-compliant opt-in cookie consent banner
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  style="display:none"
>
  <p>We use analytics cookies to improve your experience. You can opt out at any time.</p>
  <div class="cookie-actions">
    <button id="cookie-accept">Accept</button>
    <button id="cookie-decline">Decline</button>
  </div>
</div>

<style>
  #cookie-banner {
    position: fixed;
    bottom: 12px;
    left: 12px;
    right: 12px;
    width: auto;
    max-width: 640px;
    margin: 0 auto;
    background-color: var(--color-primary);
    color: white;
    padding: 16px 20px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2), 0 4px 12px rgba(0, 0, 0, 0.15);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--font-body, 'Roboto', sans-serif);
    font-size: 14px;
  }

  @media (min-width: 768px) {
    #cookie-banner {
      bottom: 20px;
      left: 20px;
      right: auto;
      margin: 0;
      max-width: 520px;
    }
  }

  #cookie-banner p {
    margin: 0;
    flex: 1;
    min-width: 200px;
  }

  .cookie-actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }

  #cookie-accept {
    background-color: white;
    color: var(--color-accent);
    border: none;
    border-radius: 8px;
    padding: 12px 18px;
    min-height: 44px;
    font-family: var(--font-heading, 'Archivo', sans-serif);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: opacity 150ms ease;
  }

  #cookie-accept:hover {
    opacity: 0.9;
  }

  #cookie-accept:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  #cookie-decline {
    background-color: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 8px;
    padding: 12px 18px;
    min-height: 44px;
    font-family: var(--font-heading, 'Archivo', sans-serif);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: opacity 150ms ease;
  }

  #cookie-decline:hover {
    opacity: 0.8;
  }

  #cookie-decline:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }
</style>

<script>
  (function() {
    const CONSENT_KEY = 'nimzo-consent';
    const banner = document.getElementById('cookie-banner');

    function getConsent() {
      try { return localStorage.getItem(CONSENT_KEY); }
      catch(e) { return null; }
    }

    function saveConsent(value: string) {
      try { localStorage.setItem(CONSENT_KEY, value); }
      catch(e) { /* localStorage unavailable */ }
    }

    function injectGA4() {
      const measurementId = 'G-F9NHXY9R8E';
      const script = document.createElement('script');
      script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
      script.async = true;
      document.head.appendChild(script);
      (window as any).dataLayer = (window as any).dataLayer || [];
      function gtag(...args: any[]) { (window as any).dataLayer.push(args); }
      (window as any).gtag = gtag;
      gtag('js', new Date());
      gtag('config', measurementId);
    }

    const consent = getConsent();

    if (consent === 'accepted') {
      injectGA4();
    } else if (consent === null && banner) {
      banner.style.display = 'flex';
    }

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      saveConsent('accepted');
      injectGA4();
      if (banner) banner.style.display = 'none';
    });

    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      saveConsent('declined');
      if (banner) banner.style.display = 'none';
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest('[data-cookie-reopen]')) {
        e.preventDefault();
        try { localStorage.removeItem(CONSENT_KEY); } catch(err) { /* noop */ }
        if (banner) banner.style.display = 'flex';
      }
    });
  })();
</script>
