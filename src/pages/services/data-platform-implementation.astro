---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import TwoColumnSplit from '../../components/content/TwoColumnSplit.astro';
import DataPlatformDiagram from '../../components/content/DataPlatformDiagram.astro';
import PricingRange from '../../components/content/PricingRange.astro';
import ProcessSteps from '../../components/content/ProcessSteps.astro';
import LogoGrid from '../../components/content/LogoGrid.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import { technologiesForGrid } from '../../data/technologies';
---

<ServiceLayout
  title="Data Platform Implementation | Nimzo Data"
  description="We build end-to-end GCP data platforms — ingestion, BigQuery, Dataform, and BI — on a fixed-price basis. For European companies ready to do data properly."
  heroTitle="You have data everywhere.<br>Nowhere useful."
  heroSubtitle="A proper data platform, without hiring a data team. We design and build end-to-end on GCP — from raw ingestion to the dashboards your team opens every morning. Fixed price. Senior engineer on every project. Documented handover so you own it when we leave."
>
  <!-- Challenges & Outcomes -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What brings most clients here.</h2>
    <TwoColumnSplit
      variant="challenges-solution"
      bare
      leftTitle="The problem:"
      leftItems={[
        "Spreadsheets are your reporting layer. They break.",
        "Manual reporting eats hours or days before every board meeting.",
        "Teams disagree on numbers. Same metric, different answers.",
        "One person is the bottleneck. Every data question routes through them.",
        "Basic questions take an afternoon. Hours of file-digging to answer.",
        "Decisions get made on gut feel. The numbers aren't trusted.",
      ]}
      rightTitle="What you get:"
      rightItems={[
        "Dashboards your team actually trusts and opens every morning.",
        "Reports that run automatically and email themselves.",
        "One definition per metric — revenue, churn, LTV.",
        "Self-service analytics — no ticket needed.",
        "Decisions grounded in data, not gut feel.",
        "Docs good enough for your next hire to take over.",
      ]}
    />
    <p class="list-footer">We build the platform, we hand you the keys, and we leave — with a 30-day support window so your team lands cleanly.</p>
  </SectionWrapper>

  <!-- Data Platform Diagram -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What we build, end to end.</h2>
    <DataPlatformDiagram />
    <p class="caption">Each layer chosen based on your data volume, team skill, and budget — not on which vendor pays partner commissions.</p>
  </SectionWrapper>

  <!-- Three layers — white cards -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Three layers. All three done right.</h2>
    <div class="layers-grid">
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 2v6"/>
            <path d="M15 2v6"/>
            <path d="M12 17v5"/>
            <path d="M5 8h14"/>
            <path d="M6 11V8h12v3a6 6 0 1 1-12 0Z"/>
          </svg>
        </div>
        <h3 class="layer-title">Automated Data Pipelines</h3>
        <p class="layer-body">We connect your data sources — databases, APIs, SaaS tools — using Airbyte or Fivetran depending on cost and reliability needs. Data lands in BigQuery on a reliable schedule, with monitoring and alerts when something breaks.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
            <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/>
            <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
          </svg>
        </div>
        <h3 class="layer-title">Data Architecture &amp; Modeling</h3>
        <p class="layer-body">Raw data is cleaned, modeled, and documented in Dataform or dbt. Staging, intermediate, and reporting layers. Data quality tests built in from the start so issues surface before they hit dashboards.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M18 17V9"/>
            <path d="M13 17V5"/>
            <path d="M8 17v-3"/>
          </svg>
        </div>
        <h3 class="layer-title">Dashboards, Reports &amp; AI-ready</h3>
        <p class="layer-body">We connect the BI tool that fits your team — Looker, Lightdash, Metabase, or Steep — and build the dashboards that matter. The platform underneath is designed so that when you're ready to add AI features, the foundation is already there.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Technologies used -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">The tools we reach for.</h2>
    <p class="intro-body">Every implementation uses some combination of these. The mix depends on your data sources, team, and budget — we explain the tradeoffs before we pick.</p>
    <LogoGrid technologies={technologiesForGrid} showTaglines={true} />
    <p class="see-all-link">
      <a href="/technologies/">See all technologies and when we pick each &rarr;</a>
    </p>
  </SectionWrapper>

  <!-- How it runs -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">How an implementation runs.</h2>
    <ProcessSteps
      steps={[
        { icon: 'rocket', title: "Kickoff & alignment (1 week)", description: "Once the proposal is signed: environment access, team alignment, deep-dive on sources and constraints. We finalize the build plan." },
        { icon: 'code-2', title: "Build (6–10 weeks, bi-weekly demos)", description: "We lead the technical work. Your team joins reviews and decisions, and can take on small parts when it makes sense. Weekly updates, demos every two weeks, no daily standups." },
        { icon: 'key-round', title: "Handover (1–2 weeks)", description: "Training sessions, full documentation, recorded walkthroughs. Your team owns it when we leave — not in theory, in practice." },
        { icon: 'life-buoy', title: "Post-launch support (30 days, included)", description: "You have questions, small tweaks, an unexpected edge case. We're reachable for 30 days after handover at no extra cost." },
      ]}
    />
  </SectionWrapper>

  <!-- Pricing -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Pricing.</h2>
    <div class="pricing-lead">
      <span class="pricing-label">Typical range</span>
      <span class="pricing-amount">€15,000 – €35,000</span>
      <p class="pricing-sub">Most projects land in this range. We quote a fixed price after the scoping call — no hourly billing, no change orders without your approval.</p>
    </div>
    <PricingRange
      factors={[
        { name: "Number of data sources", low: "2–3 simple sources", high: "6–10 mixed sources" },
        { name: "Transformation complexity", low: "Standard model", high: "Complex business logic" },
        { name: "BI tool", low: "Steep / Lightdash", high: "Looker with LookML" },
        { name: "Orchestration needs", low: "None needed", high: "Dagster-based workflow" },
      ]}
      scenarios={[
        { label: "Startup stack", price: "€15,000 – €18,000", duration: "6–8 weeks", description: "Startup with Postgres, Stripe, and HubSpot. Lightdash for dashboards." },
        { label: "Scale-up stack", price: "€25,000 – €35,000", duration: "10–14 weeks", description: "Scale-up with product databases, marketing APIs, and finance tools. Looker with LookML." },
        { label: "E-commerce stack", price: "€18,000 – €22,000", duration: "6–8 weeks", description: "E-commerce business with Shopify, advertising platforms (Meta, Google), and finance tools. Dataform + Steep for the ops team." },
      ]}
    />
    <div class="payment-section">
      <h3 class="payment-heading">Payment</h3>
      <p class="payment-body">50% at project start · 30% at the mid-project milestone · 20% on final handover. Fixed price. No change orders without a signed amendment.</p>
    </div>
  </SectionWrapper>

  <!-- After launch cross-link -->
  <SectionWrapper py="lg" bg="white">
    <div class="retainer-cta">
      <h2 class="section-heading retainer-cta__heading">After we're gone.</h2>
      <p class="retainer-cta__body">Most clients take the platform and run it themselves — that's the goal. Some prefer a safety net: monthly retainers for monitoring, improvements, and a senior on call.</p>
      <a href="/services/ongoing-support-retainers/" class="retainer-cta__link" data-track="impl-cta-retainers">
        See retainer options &rarr;
      </a>
    </div>
  </SectionWrapper>
</ServiceLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .list-footer {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .caption {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .see-all-link {
    text-align: center;
    margin: 32px 0 0 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
  }

  .see-all-link a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .see-all-link a:hover {
    text-decoration: underline;
  }

  .intro-body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0 0 32px 0;
    max-width: 720px;
  }

  .layers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .layers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .layer-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
  }

  .layer-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-teal);
  }

  .layer-icon svg {
    width: 32px;
    height: 32px;
  }

  .layer-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .layer-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  .pricing-lead {
    text-align: left;
    margin-bottom: 40px;
    max-width: 720px;
  }

  .pricing-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
  }

  .pricing-amount {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-brand-plum);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .pricing-sub {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    max-width: 720px;
    margin: 0;
    line-height: 1.6;
  }

  .retainer-cta {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .retainer-cta__heading {
    margin: 0;
  }

  .retainer-cta__body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .retainer-cta__link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }

  .retainer-cta__link:hover {
    text-decoration: underline;
  }

  .payment-section {
    margin-top: 40px;
    max-width: 720px;
  }

  .payment-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
  }

  .payment-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }
</style>
