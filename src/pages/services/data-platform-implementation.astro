---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import TwoColumnSplit from '../../components/content/TwoColumnSplit.astro';
import DataPlatformDiagram from '../../components/content/DataPlatformDiagram.astro';
import PricingRange from '../../components/content/PricingRange.astro';
import ProcessSteps from '../../components/content/ProcessSteps.astro';
import LogoGrid from '../../components/content/LogoGrid.astro';
import CTACard from '../../components/cards/CTACard.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import { technologiesForGrid } from '../../data/technologies';
---

<ServiceLayout
  title="Data Platform Implementation | Nimzo Data"
  description="We build end-to-end Google Cloud data platforms — ingestion, BigQuery, Dataform, and BI. Two phases: a paid audit first, then a fixed-price build. For European companies ready to do data properly."
  heroTitle="Your data is scattered across tools.<br>None of it talks to each other."
  heroSubtitle="A proper data platform, without hiring a data team. End-to-end — ingestion to dashboards. Two phases — audit first, then a fixed-price build. Senior engineering, clean handover."
>
  <!-- Challenges & Outcomes -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What brings most clients here.</h2>
    <TwoColumnSplit
      variant="challenges-solution"
      bare
      leftTitle="The problem:"
      leftItems={[
        "Spreadsheets are your reporting layer. They break.",
        "Manual reporting eats hours or days before every board meeting.",
        "Teams disagree on numbers. Same metric, different answers.",
        "One person is the bottleneck. Every data question routes through them.",
        "Basic questions take an afternoon. Hours of file-digging to answer.",
        "Decisions get made on gut feel. The numbers aren't trusted.",
      ]}
      rightTitle="What you get:"
      rightItems={[
        "Dashboards your team trusts and opens every morning.",
        "Reports that run automatically and email themselves.",
        "One definition per metric — revenue, churn, LTV.",
        "Self-service analytics — no ticket needed.",
        "Decisions grounded in data, not gut feel.",
        "Docs good enough for your next hire to take over.",
      ]}
    />
    <p class="list-footer">We build the platform, we hand you the keys, and we leave — with a 30-day support window so your team lands cleanly.</p>
  </SectionWrapper>

  <!-- Data Platform Diagram -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What we build, end to end.</h2>
    <DataPlatformDiagram />
    <p class="caption">Each layer chosen based on your data volume, team skill, and budget — not on which vendor pays partner commissions.</p>
  </SectionWrapper>

  <!-- Three layers — white cards -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Three layers. All three done right.</h2>
    <div class="layers-grid">
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 2v6"/>
            <path d="M15 2v6"/>
            <path d="M12 17v5"/>
            <path d="M5 8h14"/>
            <path d="M6 11V8h12v3a6 6 0 1 1-12 0Z"/>
          </svg>
        </div>
        <h3 class="layer-title">Automated Data Pipelines</h3>
        <p class="layer-body">We connect your data sources — databases, APIs, SaaS tools — using Airbyte or Fivetran, depending on your needs. Data lands in BigQuery on a reliable schedule, with monitoring and alerts when something breaks.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
            <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/>
            <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
          </svg>
        </div>
        <h3 class="layer-title">Data Architecture &amp; Modeling</h3>
        <p class="layer-body">Raw data is cleaned, modeled, and documented in Dataform or dbt. Staging, transformation, and reporting layers. Data quality tests built in from the start so issues surface before they hit dashboards.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M18 17V9"/>
            <path d="M13 17V5"/>
            <path d="M8 17v-3"/>
          </svg>
        </div>
        <h3 class="layer-title">Dashboards, Reports &amp; AI-ready</h3>
        <p class="layer-body">We connect the BI tool that fits your team — Looker, Lightdash, Metabase, or Steep — and build the dashboards that matter. The platform underneath is designed so that when you're ready to add AI features, the foundation is already there.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Technologies used -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">The tools we reach for.</h2>
    <p class="intro-body">Every implementation uses some combination of these. The mix depends on your data sources, team, and budget — we explain the tradeoffs before we pick.</p>
    <LogoGrid technologies={technologiesForGrid} showTaglines={true} />
    <p class="see-all-link">
      <a href="/technologies/">See all technologies and when we pick each &rarr;</a>
    </p>
  </SectionWrapper>

  <!-- How it runs -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">How an implementation runs.</h2>
    <ProcessSteps
      steps={[
        { icon: 'search', title: "Audit (1–2 weeks, €3,000 – €5,000)", description: "Sources, volumes, and tools evaluated. Written recommendation and fixed-price build proposal. <a href='/services/data-platform-audit/' class='step-link'>Available standalone</a>." },
        { icon: 'scale', title: "Your decision (no pressure, no fees for deciding)", description: "Proceed with the build, do it yourselves, or stop here. Plenty of clients take the report and execute internally." },
        { icon: 'code-2', title: "Build (6–10 weeks, bi-weekly demos)", description: "We lead the technical work. Your team joins reviews and decisions, and can take on small parts when it makes sense. Bi-weekly demos, async by default." },
        { icon: 'key-round', title: "Handover (1–2 weeks)", description: "Training sessions, full documentation, recorded walkthroughs. Your team owns it when we leave — not in theory, in practice." },
        { icon: 'life-buoy', title: "Post-launch support (30 days, included)", description: "You have questions, small tweaks, an unexpected edge case. We're reachable for 30 days after handover at no extra cost." },
      ]}
    />
  </SectionWrapper>

  <!-- Pricing -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Pricing.</h2>
    <div class="two-phase-grid">
      <div class="phase-card">
        <div class="phase-label">Phase 1 — Audit</div>
        <div class="phase-price">€3,000 – €5,000</div>
        <p class="phase-sub">1–2 weeks, fixed price, paid 100% upfront. Written recommendation and fixed-price build proposal. Same audit available <a href="/services/data-platform-audit/" class="inline-link">standalone</a>.</p>
      </div>
      <div class="phase-card">
        <div class="phase-label">Phase 2 — Build (optional)</div>
        <div class="phase-price">€12,000 – €30,000</div>
        <p class="phase-sub">7–12 weeks (build + handover), priced after the audit based on the real scope. Fixed price, agreed before we start.</p>
      </div>
    </div>
    <p class="total-callout">Total range when clients do both phases: €15,000 – €35,000.</p>

    <PricingRange
      factors={[
        { name: "Number of data sources", low: "2–3 simple sources", high: "6–10 mixed sources" },
        { name: "Transformation complexity", low: "Standard model", high: "Complex business logic" },
        { name: "BI tool", low: "Steep / Metabase", high: "Lightdash / Looker with LookML" },
        { name: "Orchestration needs", low: "None needed", high: "Dagster-based workflow" },
      ]}
      scenarios={[
        { label: "Example: 3 sources, Metabase", price: "€15,000 – €18,000", duration: "8–10 weeks", description: "Startup with Postgres, Stripe, and HubSpot. Metabase for dashboards." },
        { label: "Example: 6+ sources, Looker", price: "€25,000 – €35,000", duration: "10–14 weeks", description: "Scale-up with product databases, marketing APIs, and finance tools. Looker with LookML." },
        { label: "Example: Shopify + ads, Lightdash", price: "€18,000 – €22,000", duration: "8–10 weeks", description: "E-commerce business with Shopify, advertising platforms (Meta, Google), and finance tools. Lightdash for the ops team." },
      ]}
    />
    <div class="payment-section">
      <h3 class="payment-heading">Payment</h3>
      <p class="payment-body">Audit 100% at audit kickoff. Build 50% at start · 30% at the mid-project milestone · 20% on final handover. Fixed price. No change orders without a signed amendment.</p>
    </div>
  </SectionWrapper>

  <!-- Cross-links: not the right fit -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Not sure this is the right fit?</h2>
    <div class="cta-cards-grid cta-cards-grid--three">
      <CTACard
        title="Platform exists but not working?"
        description="Audit what you have, then build the improvements. Two phases — audit first, then a fixed-price build."
        href="/services/data-platform-optimization/"
        buttonText="See Optimization"
        dataTrack="impl-cta-optimization"
        variant="link"
      />
      <CTACard
        title="Scope is narrower than a full build?"
        description="Focused help on one or two layers — Dataform, Looker, BigQuery costs. Fixed-price, 2–6 weeks."
        href="/services/expert-implementation-services/"
        buttonText="See Expert Services"
        dataTrack="impl-cta-expert"
        variant="link"
      />
      <CTACard
        title="Already have a working platform?"
        description="Monthly retainer for monitoring, incident response, improvements, and a senior engineer on call."
        href="/services/ongoing-support-retainers/"
        buttonText="See Ongoing Support"
        dataTrack="impl-cta-retainers"
        variant="link"
      />
    </div>
  </SectionWrapper>
</ServiceLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .list-footer {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .caption {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .see-all-link {
    text-align: center;
    margin: 32px 0 0 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
  }

  .see-all-link a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .see-all-link a:hover {
    text-decoration: underline;
  }

  .intro-body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0 0 32px 0;
    max-width: 720px;
  }

  .layers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .layers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .layer-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
  }

  .layer-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-teal);
  }

  .layer-icon svg {
    width: 32px;
    height: 32px;
  }

  .layer-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .layer-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  .two-phase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }

  @media (min-width: 768px) {
    .two-phase-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .phase-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .phase-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .phase-price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-brand-plum);
    line-height: 1.1;
  }

  .phase-sub {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 4px 0 0 0;
  }

  .total-callout {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0 0 40px 0;
  }

  .inline-link {
    color: var(--color-primary);
    text-decoration: underline;
    font-weight: 500;
  }

  .cta-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .cta-cards-grid--three {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  /* Inline link inside ProcessSteps descriptions */
  :global(.step-link) {
    color: var(--color-primary);
    text-decoration: underline;
    font-weight: 500;
  }

  .payment-section {
    margin-top: 40px;
    max-width: 720px;
  }

  .payment-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
  }

  .payment-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }
</style>
