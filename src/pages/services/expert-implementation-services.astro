---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceCardSmall from '../../components/cards/ServiceCardSmall.astro';
import ProcessSteps from '../../components/content/ProcessSteps.astro';
import CTACard from '../../components/cards/CTACard.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
---

<ServiceLayout
  title="Expert Implementation Services | Nimzo Data"
  description="Targeted Google Cloud data engineering help: BigQuery optimization, Dataform setup, ETL pipelines, or BI implementation. Fixed-price. Defined scope."
  heroTitle="Focused help on your data stack."
  heroSubtitle="You know what you need. Senior data engineering expertise for focused work — a Dataform rebuild, a Looker semantic layer, BigQuery costs tamed. Fixed-price, 2–6 weeks, no long engagement."
>
  <!-- Who this is for — bare list -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Who this is for.</h2>
    <ul class="tick-list">
      <li>You know exactly what you need — one specific problem solved.</li>
      <li>You have a GCP data stack, and one layer is broken or missing.</li>
      <li>Your team can handle most of the platform, just not this thing.</li>
      <li>You completed a platform audit and want help on the hardest fixes.</li>
    </ul>
    <p class="list-footer">If you need multiple services at once, or aren't sure which service you need, a full implementation or optimization engagement is usually a better fit. We tell you which on the discovery call.</p>
  </SectionWrapper>

  <!-- 5 expert services — 3 + 2 layout -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Our expert services.</h2>
    <div class="expert-grid">
      <ServiceCardSmall
        title="Dataform / dbt Implementation"
        priceRange="€5,000 – €12,000"
        timeline="2–4 weeks"
        details={[
          "Project setup, staging and mart models",
          "Data quality tests, CI/CD, team training",
          "Migrate spaghetti SQL into maintainable transformations",
        ]}
      />
      <ServiceCardSmall
        title="BI & Analytics Development"
        priceRange="€6,000 – €15,000"
        timeline="3–6 weeks"
        details={[
          "Looker LookML modeling for enterprise governance",
          "Lightdash / Metabase / Steep setup — semantic layer, dashboards, AI assistant config",
          "Initial dashboards and user training",
        ]}
      />
      <ServiceCardSmall
        title="ETL / ELT Pipeline Implementation"
        priceRange="€5,000 – €15,000"
        timeline="2–5 weeks"
        details={[
          "Airbyte or Fivetran setup",
          "Datastream CDC for large databases",
          "Custom Cloud Functions, monitoring and alerts",
        ]}
      />
      <ServiceCardSmall
        title="BigQuery Optimization"
        priceRange="€4,000 – €10,000"
        timeline="2–3 weeks"
        details={[
          "Query performance audit",
          "Partitioning, clustering, materialized views",
          "Typical: 60–90% cost reduction on rewritten queries",
        ]}
      />
      <ServiceCardSmall
        title="Custom Data Integrations"
        priceRange="€5,000 – €12,000"
        timeline="2–4 weeks"
        details={[
          "API integrations via Cloud Functions",
          "Bespoke transformation logic nobody else will touch",
          "Custom connectors where Airbyte and Fivetran don't fit",
        ]}
      />
    </div>
  </SectionWrapper>

  <!-- How it works -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">How an expert engagement runs.</h2>
    <ProcessSteps
      steps={[
        { icon: 'search', title: "Technical assessment", description: "Once the proposal is signed: read access to your GCP environment and a 1–2 hour technical interview with your data lead. We confirm the plan." },
        { icon: 'code-2', title: "Build (2–6 weeks, weekly check-ins)", description: "We do the work. Weekly updates. Your team joins reviews and can take on small parts when it makes sense. No daily standups." },
        { icon: 'key-round', title: "Handover", description: "Documentation and a walkthrough session. Your team owns what we built — no trailing retainer expected." },
        { icon: 'life-buoy', title: "Post-launch support (30 days, included)", description: "Questions, small tweaks, an unexpected edge case. We're reachable for 30 days after handover at no extra cost." },
      ]}
    />
  </SectionWrapper>

  <!-- Payment -->
  <SectionWrapper py="md" bg="white">
    <div class="payment-section">
      <h3 class="payment-heading">Payment</h3>
      <p class="payment-body">50% at engagement start, 50% on delivery. Fixed price, agreed in writing before work begins.</p>
    </div>
  </SectionWrapper>

  <!-- Not the right scope? -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Not the right scope for you?</h2>
    <div class="cta-cards-grid">
      <CTACard
        title="No data platform yet? Start fresh."
        description="Build end-to-end from scratch: ingestion, transformations, dashboards. Audit first, then a fixed-price build."
        href="/services/data-platform-implementation/"
        buttonText="See Implementation"
        variant="link"
      />
      <CTACard
        title="Platform exists but not working?"
        description="Audit what you have, then build the improvements. Two phases: audit first, then a fixed-price build."
        href="/services/data-platform-optimization/"
        buttonText="See Optimization"
        variant="link"
      />
      <CTACard
        title="Need ongoing support, not one-time work?"
        description="Monthly retainer for monitoring, incident response, improvements, and a senior engineer on call."
        href="/services/ongoing-support-retainers/"
        buttonText="See Ongoing Support"
        variant="link"
      />
    </div>
  </SectionWrapper>

</ServiceLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .tick-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 820px;
  }

  .tick-list li {
    position: relative;
    padding-left: 28px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .tick-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 5px;
    width: 18px;
    height: 18px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 18 18'><circle cx='9' cy='9' r='9' fill='%23004f4c' fill-opacity='0.12'/><path d='M5 9.5L7.5 12L13 7' stroke='%23004f4c' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
  }

  .list-footer {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .expert-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .expert-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .expert-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .payment-section {
    max-width: 720px;
  }

  .payment-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
  }

  .payment-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .cta-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .cta-cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
