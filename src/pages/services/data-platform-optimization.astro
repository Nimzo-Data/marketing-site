---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import TwoColumnSplit from '../../components/content/TwoColumnSplit.astro';
import DataPlatformDiagram from '../../components/content/DataPlatformDiagram.astro';
import PricingRange from '../../components/content/PricingRange.astro';
import ProcessSteps from '../../components/content/ProcessSteps.astro';
import LogoGrid from '../../components/content/LogoGrid.astro';
import ResultBlock from '../../components/content/ResultBlock.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import { technologiesForGrid } from '../../data/technologies';
---

<ServiceLayout
  title="Data Platform Optimization | Nimzo Data"
  description="We audit and fix GCP data platforms — BigQuery costs, slow dashboards, broken pipelines. Two phases: audit, then fix. Fixed price."
  heroTitle="Your data platform exists.<br>It isn't working."
  heroSubtitle="We audit what you have, tell you what's actually wrong, and implement a prioritized fix. Two phases — audit first, implementation second. Senior engineer on every project."
>
  <!-- Challenges & Outcomes -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What brings most clients here.</h2>
    <TwoColumnSplit
      variant="challenges-solution"
      bare
      leftTitle="The problem:"
      leftItems={[
        "BigQuery costs tripled in six months. No one knows why.",
        "Dashboards take 45 seconds. People stopped opening them.",
        "Pipelines break weekly. You hear about it from tickets.",
        "You inherited a platform. Nobody knows what half of it does.",
        "Finance says revenue is X. Product says Y. Leadership believes neither.",
        "Nobody uses the BI tool — the data isn't trusted.",
      ]}
      rightTitle="What you get:"
      rightItems={[
        "A written audit you can act on — not slideware.",
        "A prioritized fix list, ranked by cost vs impact.",
        "Reliable pipelines with alerts before users notice.",
        "Queries and dashboards that load in seconds, not minutes.",
        "One definition per metric your business runs on.",
        "A BI tool people actually use, with trustworthy data.",
      ]}
    />
  </SectionWrapper>

  <!-- Diagram -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">The target. What your platform should look like.</h2>
    <DataPlatformDiagram />
    <p class="caption">You probably have some of these layers. Some are missing. Some exist but need replacing. The audit tells us which.</p>
  </SectionWrapper>

  <!-- Three layers we fix -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Three layers. Same three we fix.</h2>
    <div class="layers-grid">
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 2v6"/>
            <path d="M15 2v6"/>
            <path d="M12 17v5"/>
            <path d="M5 8h14"/>
            <path d="M6 11V8h12v3a6 6 0 1 1-12 0Z"/>
          </svg>
        </div>
        <h3 class="layer-title">Data Pipelines</h3>
        <p class="layer-body">Replace legacy Python scripts with Airbyte. Add monitoring and alerting that actually fire. Fix the three pipelines nobody touches because they scare everyone.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
            <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/>
            <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
          </svg>
        </div>
        <h3 class="layer-title">Data Architecture &amp; Modeling</h3>
        <p class="layer-body">Refactor the models nobody understands. Cut BigQuery costs with partitioning, clustering, and query rewrites. Add tests so data quality issues stop reaching your dashboards.</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M18 17V9"/>
            <path d="M13 17V5"/>
            <path d="M8 17v-3"/>
          </svg>
        </div>
        <h3 class="layer-title">Dashboards, Reports &amp; AI-ready</h3>
        <p class="layer-body">Migrate off BI tools your team has given up on. Rebuild trust in the numbers by rebuilding the numbers. Set up the semantic layer so when you're ready for AI features, the foundation holds up.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Technologies used -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">The tools we work with — yours and ours.</h2>
    <p class="intro-body">We work with your existing stack first. If something needs replacing, we tell you why and what we'd use instead.</p>
    <LogoGrid technologies={technologiesForGrid} showTaglines={true} />
    <p class="see-all-link">
      <a href="/technologies/">See all technologies and when we pick each &rarr;</a>
    </p>
  </SectionWrapper>

  <!-- How it runs -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">How an optimization runs.</h2>
    <ProcessSteps
      steps={[
        { icon: 'search', title: "Audit (1–2 weeks, €3,000 – €5,000)", description: "We review your GCP architecture, query costs, pipeline reliability, and data quality. We interview your team. You get a written report and a prioritized fix list." },
        { icon: 'scale', title: "Your decision (no pressure, no fees for deciding)", description: "Proceed with the implementation, do it yourselves, or stop here. The audit is valuable on its own — plenty of clients take the report and execute internally." },
        { icon: 'code-2', title: "Implementation (6–10 weeks)", description: "We implement the fixes from the audit — in the priority order you approved. Fixed price, agreed before we start." },
        { icon: 'key-round', title: "Handover (1–2 weeks)", description: "Training, documentation, recorded walkthroughs. Same as a greenfield build, just on the platform we improved." },
        { icon: 'life-buoy', title: "Post-launch support (30 days, included)", description: "30 days of reachability for questions, tweaks, edge cases." },
      ]}
    />
  </SectionWrapper>

  <!-- Pricing -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Pricing.</h2>
    <div class="two-phase-grid">
      <div class="phase-card">
        <div class="phase-label">Phase 1 — Audit</div>
        <div class="phase-price">€3,000 – €5,000</div>
        <p class="phase-sub">1–2 weeks, fixed price. You get a written audit report and a prioritized fix list. You can stop here and execute internally — the audit fee is yours either way.</p>
      </div>
      <div class="phase-card phase-card--highlighted">
        <div class="phase-label">Phase 2 — Implementation (optional)</div>
        <div class="phase-price">€17,000 – €45,000</div>
        <p class="phase-sub">6–10 weeks, priced after the audit based on scope. If you proceed, the audit fee is credited toward the implementation.</p>
      </div>
    </div>
    <p class="total-callout">Total range when clients do both phases: €20,000 – €50,000.</p>

    <PricingRange
      factors={[
        { name: "Current state", low: "Mostly working", high: "Fundamentally broken" },
        { name: "Technical debt", low: "Isolated issues", high: "Systemic across layers" },
        { name: "Migration scope", low: "Keep most tools", high: "Replace legacy stack" },
        { name: "BI tool migration", low: "Stay on current tool", high: "Migrate to new tool" },
      ]}
      scenarios={[
        { label: "Performance & cost", price: "€20,000 – €25,000", duration: "8–10 weeks", description: "Performance and cost optimization — schema redesign, query tuning." },
        { label: "Tool modernization", price: "€25,000 – €35,000", duration: "10–12 weeks", description: "Tool modernization — move legacy Python to Airbyte, add Dataform." },
        { label: "Major overhaul", price: "€40,000 – €50,000", duration: "12–16 weeks", description: "Major overhaul — multiple migrations, complex data quality issues." },
      ]}
    />

    <div class="why-more">
      <h3 class="why-more-title">Why is this more expensive than building from scratch?</h3>
      <p class="why-more-intro">Two reasons.</p>
      <div class="why-more__grid">
        <div class="why-more__reason">
          <h4 class="why-more__sub">Investigation</h4>
          <p>We spend the first week of every optimization understanding what previous engineers built — decisions made by people who may no longer be at the company, working around constraints we didn't create.</p>
        </div>
        <div class="why-more__reason">
          <h4 class="why-more__sub">Interconnection</h4>
          <p>Most broken platforms have connected problems. Fixing the slow dashboard means fixing the transformation model, which means fixing the pipeline that feeds it. We price to cover that investigation, not just the final fix.</p>
        </div>
      </div>
    </div>

    <div class="payment-section">
      <h3 class="payment-heading">Payment</h3>
      <p class="payment-body">Audit 100% at audit kickoff. Implementation 50% at start · 30% at the mid-project milestone · 20% on final handover. Fixed price. No change orders without a signed amendment.</p>
    </div>
  </SectionWrapper>

  <!-- After launch -->
  <SectionWrapper py="lg" bg="white">
    <div class="retainer-cta">
      <h2 class="section-heading retainer-cta__heading">Keeping it fixed.</h2>
      <p class="retainer-cta__body">An optimized platform needs less maintenance than a broken one, but it still needs some. Monthly retainers cover monitoring, small improvements, and a senior on call.</p>
      <a href="/services/ongoing-support-retainers/" class="retainer-cta__link" data-track="opt-cta-retainers">
        See retainer options &rarr;
      </a>
    </div>
  </SectionWrapper>

  <!-- Proof: Aeyde result block -->
  <SectionWrapper py="lg" bg="white">
    <ResultBlock
      metric="From minutes to seconds."
      body="Plus a 77% drop in infrastructure costs and 119 Looker derived tables collapsed into a single Dataform layer."
      caseStudySlug="aeyde"
    />
  </SectionWrapper>
</ServiceLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .caption {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 24px 0 0 0;
    max-width: 720px;
  }

  .see-all-link {
    text-align: center;
    margin: 32px 0 0 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
  }

  .see-all-link a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .see-all-link a:hover {
    text-decoration: underline;
  }

  .intro-body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0 0 32px 0;
    max-width: 720px;
  }

  .layers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .layers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .layer-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
  }

  .layer-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-teal);
  }

  .layer-icon svg {
    width: 32px;
    height: 32px;
  }

  .layer-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .layer-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  .two-phase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }

  @media (min-width: 768px) {
    .two-phase-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .phase-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .phase-card--highlighted {
    border: 2px solid var(--color-brand-plum);
  }

  .phase-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .phase-price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-brand-plum);
    line-height: 1.1;
  }

  .phase-sub {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 4px 0 0 0;
  }

  .total-callout {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0 0 40px 0;
  }

  .why-more {
    margin-top: 40px;
  }

  .why-more-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 16px 0;
  }

  .why-more p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0 0 16px 0;
  }

  .why-more p:last-child { margin-bottom: 0; }

  .why-more__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 16px;
  }

  @media (min-width: 768px) {
    .why-more__grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .why-more__sub {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-plum);
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .why-more__reason p {
    margin: 0;
  }

  .retainer-cta {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .retainer-cta__heading {
    margin: 0;
  }

  .retainer-cta__body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .retainer-cta__link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }

  .retainer-cta__link:hover {
    text-decoration: underline;
  }

  .payment-section {
    margin-top: 40px;
    max-width: 720px;
  }

  .payment-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
  }

  .payment-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }
</style>
