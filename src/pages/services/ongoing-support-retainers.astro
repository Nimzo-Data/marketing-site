---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import RetainerGrid from '../../components/content/RetainerGrid.astro';
import CTACard from '../../components/cards/CTACard.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import { retainerTiers, retainerRows } from '../../data/retainers';
---

<ServiceLayout
  title="Ongoing Support & Retainers | Nimzo Data"
  description="Monthly GCP data platform retainers — monitoring, incident response, and continuous improvement. Three tiers from €1,000 to €4,000/month. Month-to-month."
  heroTitle="Your platform is live. Someone still has to keep it running."
  heroSubtitle="Monthly retainers for monitoring, incident response, and continuous improvement — so you don't need to hire a full-time data engineer to keep things healthy."
>
  <!-- Who this is for -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Who this is for.</h2>
    <div class="who-card">
      <ul class="tick-list">
        <li>You have a working data platform (built by us or someone else) and you want it to stay working.</li>
        <li>Your data lead wears three hats and can't dedicate time to platform maintenance.</li>
        <li>You want a senior technical resource on call without full-time hiring cost.</li>
        <li>You're growing fast and want architecture guidance as your data needs scale.</li>
      </ul>
    </div>
    <p class="list-footer">Not the right fit if you don't have a platform yet — retainers work best on top of a solid foundation. If you're earlier than that, start with an implementation or optimization engagement.</p>
  </SectionWrapper>

  <!-- Retainer pricing -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Three tiers.</h2>
    <RetainerGrid tiers={retainerTiers} rows={retainerRows} />
  </SectionWrapper>

  <!-- Highlighted "What fits in those hours" -->
  <SectionWrapper py="md" bg="white">
    <div class="fits-card">
      <h3 class="fits-heading">What fits in those hours?</h3>
      <p>Growth (16 hours) typically covers one new data source or two to three new dashboards a month, on top of ongoing support. Partnership (32 hours) is roughly one day a week of dedicated capacity.</p>
    </div>
  </SectionWrapper>

  <!-- How the retainer works — LIGHT GREY-TEAL SECTION -->
  <SectionWrapper py="lg" bg="card">
    <h2 class="section-heading">How the retainer works.</h2>
    <ul class="plain-list">
      <li><strong>Month-to-month.</strong> 30-day written notice to end or change tier. No minimum commitment.</li>
      <li>Hours are tracked monthly and don't roll over.</li>
      <li>Work beyond included hours: €150/hour.</li>
      <li>Large requests that would use most of your monthly hours at once may be quoted as a separate mini-project, keeping your retainer hours free for smaller work.</li>
      <li>Response times above refer to business hours, Monday to Friday (Central European Time).</li>
    </ul>

    <div class="example-card">
      <h3 class="example-heading">Example</h3>
      <p>You're on the Growth tier (16 hours/month). Halfway through the month you ask for a new Salesforce integration plus a sales dashboard — about 15 hours of work. We give you options: fit it this month (keep one hour for support), split it across two months, or scope it as a €2,000 mini-project so your retainer hours stay free.</p>
    </div>
  </SectionWrapper>

  <!-- Not there yet? -->
  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Not there yet?</h2>
    <p class="intro-body">Retainers work best on top of a working platform. If you're earlier:</p>
    <div class="cta-cards-grid">
      <CTACard
        title="No data platform yet?"
        description="Build end-to-end from scratch."
        href="/services/data-analytics-platform-implementation/"
        buttonText="See Implementation"
      />
      <CTACard
        title="Platform exists but broken?"
        description="Audit what you have, then fix what matters."
        href="/services/data-analytics-platform-optimization/"
        buttonText="See Optimization"
      />
      <CTACard
        title="Need focused expert help on one thing?"
        description="Fixed-price engagements, 2–6 weeks."
        href="/services/expert-implementation-services/"
        buttonText="See Expert Services"
      />
    </div>
  </SectionWrapper>
</ServiceLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .who-card {
    background-color: var(--color-card);
    border-radius: var(--radius-card);
    padding: 32px;
    max-width: 820px;
  }

  .tick-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .tick-list li {
    position: relative;
    padding-left: 28px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .tick-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 5px;
    width: 18px;
    height: 18px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 18 18'><circle cx='9' cy='9' r='9' fill='%23004f4c' fill-opacity='0.12'/><path d='M5 9.5L7.5 12L13 7' stroke='%23004f4c' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
  }

  .list-footer {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 24px 0 0 0;
    max-width: 820px;
  }

  .fits-card {
    background-color: var(--color-card);
    border-radius: var(--radius-card);
    padding: 24px;
    max-width: 820px;
  }

  .fits-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
  }

  .fits-card p {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .plain-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 820px;
  }

  .plain-list li {
    position: relative;
    padding-left: 20px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .plain-list li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .example-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-card);
    border-radius: var(--radius-card);
    padding: 24px;
    max-width: 820px;
    margin-top: 24px;
  }

  .example-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0 0 8px 0;
  }

  .example-card p {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .intro-body {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 24px 0;
    max-width: 720px;
  }

  .cta-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .cta-cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
