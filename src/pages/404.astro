---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
---

<BaseLayout
  title="Page Not Found | Nimzo Data"
  description="This page doesn't exist."
>
  <SectionWrapper py="xl">
    <div class="not-found">
      <h1 class="not-found-heading">This page doesn't exist.</h1>
      <p class="not-found-body">You might have followed a broken link or mistyped the URL. Either way, there's nothing here. Let's get you somewhere useful.</p>
      <a href="/" class="not-found-link">Go to the homepage &rarr;</a>
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .not-found-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
  }

  .not-found-body {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .not-found-link {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: underline;
    transition: opacity 150ms ease;
  }

  .not-found-link:hover {
    opacity: 0.75;
  }
</style>
