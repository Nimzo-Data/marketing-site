---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroStandard from '../components/heroes/HeroStandard.astro';
import TextSection from '../components/content/TextSection.astro';
import TwoColumnSplit from '../components/content/TwoColumnSplit.astro';
import CTABanner from '../components/cards/CTABanner.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';

const leftItems = [
  "You're on Google Cloud, or planning to be.",
  "You're past the \"spreadsheet era\" and need a real platform.",
  "You have analysts, not data engineers — or no team at all.",
  "You need senior data engineering — and don't want to hire for it.",
  "You can make a decision. Our best engagements start in two-week sales cycles, not four-month ones.",
];

const rightItems = [
  "You need AWS or Azure. We don't do multi-cloud.",
  "You're pre-product-market-fit. Data isn't your bottleneck yet.",
  "You need analysts or data scientists. We're data engineers.",
  "You want the cheapest hourly rate available. We compete on seniority, not price.",
  "You need real-time streaming at scale — Kafka, Flink, sub-second latency. Different specialism.",
];

type PrincipleIcon = 'compass' | 'database' | 'target' | 'tag' | 'message-square' | 'graduation-cap';

const principles: Array<{ icon: PrincipleIcon; title: string; body: string }> = [
  {
    icon: 'compass',
    title: 'Execution-led, not embedded',
    body: "We lead the technical work. Your team joins reviews and decisions, and can take on small parts when it makes sense. No daily standups, no full embed — different from staff augmentation or intensive enablement.",
  },
  {
    icon: 'database',
    title: 'Infrastructure first, insights second',
    body: "The most impressive dashboard is worthless if the data feeding it isn't reliable. We build the plumbing before anyone talks about taps.",
  },
  {
    icon: 'target',
    title: 'One cloud, by design',
    body: "GCP-only isn't a limitation. It's a commitment to depth over breadth. Multi-cloud consultancies are necessarily shallow on each cloud.",
  },
  {
    icon: 'tag',
    title: 'Transparent pricing, defined scope',
    body: "Data consulting has a reputation for ballooning engagements. Fixed prices, ranges published on our service pages, no upsells on work you don't need.",
  },
  {
    icon: 'message-square',
    title: 'European sensibility, direct communication',
    body: "Based in France, working across Europe. No Silicon Valley vocabulary. We say what we mean and we say it short.",
  },
  {
    icon: 'graduation-cap',
    title: 'Capable teams over dependent clients',
    body: "Every engagement ends with documentation, training, and a clean handover. Your team understands what we built and why. If you outgrow us, that's a success.",
  },
];
---

<BaseLayout
  title="About | Nimzo Data"
  description="Nimzo Data is a boutique GCP data consultancy based in France. Modern data infrastructure for ambitious European companies. Fixed-price projects, senior engineering only."
>
  <HeroStandard
    title="A boutique GCP data consultancy.<br>By design."
    subtitle="Small team. One cloud. Fixed-price projects. We work with a handful of clients at a time and go deep, not wide."
    cta={{ text: "Let's talk", href: '/contact/', dataTrack: 'about-hero-cta' }}
  />

  <!-- Why Nimzo Data exists — editorial with sub-heads -->
  <SectionWrapper bg="white" py="lg">
    <div class="exists-section">
      <h2 class="section-heading">Why Nimzo Data exists.</h2>
      <div class="reasons">
        <div class="reason">
          <h3 class="reason-title">A gap in the market</h3>
          <p>Most data consultancies pitch themselves as trusted advisors and deliver what looks like transformation theater. Beautiful slide decks, expensive audits, and not much working software at the end. The mid-market in Europe deserves better: serious technical work, delivered honestly, at prices that aren't calibrated for Big Four budgets.</p>
        </div>
        <div class="reason">
          <h3 class="reason-title">One thing, done well</h3>
          <p>We built Nimzo Data to do that one thing well. GCP, because it's the best analytics stack available. Fixed-price, because hourly billing rewards the wrong behavior. Senior engineering only, because the problems clients bring us can't be fixed by juniors learning on the job.</p>
        </div>
        <div class="reason">
          <h3 class="reason-title">Deliberately small</h3>
          <p>We're deliberately small. Taking on fewer clients means we can actually care about each one.</p>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <TextSection title="Why Nimzo?" bg="white">
    <p>Nimzo Data takes its name from the Nimzo-Indian Defense — a chess opening known for controlling the center through indirect pressure rather than direct occupation. The Nimzo-Indian doesn't charge forward. It creates the conditions for a structural advantage that compounds over time.</p>
    <p>We build data infrastructure the same way. We're not interested in impressive-looking dashboards that don't connect to decisions. We're interested in creating the conditions for insight: clean pipelines, reliable models, clear metrics, and systems that compound in value as your data grows.</p>
  </TextSection>

  <!-- How we work -->
  <SectionWrapper bg="white" py="lg">
    <h2 class="section-heading">How we work.</h2>
    <div class="principles-grid">
      {principles.map((p) => (
        <div class="principle-card">
          <div class="principle-icon" aria-hidden="true">
            {p.icon === 'compass' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
              </svg>
            )}
            {p.icon === 'database' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M3 5V19A9 3 0 0 0 21 19V5"/>
                <path d="M3 12A9 3 0 0 0 21 12"/>
              </svg>
            )}
            {p.icon === 'target' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            )}
            {p.icon === 'tag' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
                <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
              </svg>
            )}
            {p.icon === 'message-square' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            )}
            {p.icon === 'graduation-cap' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/>
                <path d="M22 10v6"/>
                <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>
              </svg>
            )}
          </div>
          <h3 class="principle-title">{p.title}</h3>
          <p class="principle-body">{p.body}</p>
        </div>
      ))}
    </div>
  </SectionWrapper>

  <SectionWrapper bg="white" py="lg">
    <h2 class="section-heading">Who we work with.</h2>
    <TwoColumnSplit
      variant="is-for"
      bare
      leftTitle="This is for you if:"
      leftItems={leftItems}
      rightTitle="This isn't for you if:"
      rightItems={rightItems}
    />
  </SectionWrapper>

  <CTABanner dataTrack="about-cta" />
</BaseLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .exists-section {
    max-width: 820px;
  }

  .reasons {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .reason-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .reason p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .principles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .principles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .principle-card {
    background-color: var(--color-bg-default);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border-subtle);
    box-shadow: var(--shadow-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .principle-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-teal);
  }

  .principle-icon svg {
    width: 28px;
    height: 28px;
  }

  .principle-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .principle-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.65;
  }
</style>
