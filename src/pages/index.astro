---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nimzo Data — Design Token Test</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div style="max-width: 800px; margin: 40px auto; padding: 0 24px;">
    <h1>Nimzo Data</h1>
    <p>GCP Data Consulting Agency</p>
    <p class="text-[var(--color-text-secondary)]">Design tokens loaded successfully.</p>
    <div style="display: flex; gap: 16px; margin-top: 32px; flex-wrap: wrap;">
      <div style="background: var(--color-primary); color: white; padding: 16px; border-radius: var(--radius-card); font-family: var(--font-body);">#004f4c Primary</div>
      <div style="background: var(--color-accent); color: white; padding: 16px; border-radius: var(--radius-card); font-family: var(--font-body);">#493441 Accent</div>
      <div style="background: var(--color-card); padding: 16px; border-radius: var(--radius-card); font-family: var(--font-body);">#dee7e7 Card</div>
    </div>
  </div>
</body>
</html>
