---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroStandard from '../components/heroes/HeroStandard.astro';
import TextSection from '../components/content/TextSection.astro';
import ProcessSteps from '../components/content/ProcessSteps.astro';
import CTACard from '../components/cards/CTACard.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
---

<BaseLayout
  title="Contact | Nimzo Data"
  description="45-minute call about your data stack. No sales pitch. We tell you honestly whether we're a fit. hello@nimzodata.com."
>
  <HeroStandard
    title="Let's talk about your data stack."
    subtitle="45-minute call. We ask about your current setup, what isn't working, and what you want to achieve. No sales pitch. Just an honest conversation about whether we're a fit."
  />

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading section-heading--with-sub">Pick a time that works.</h2>
    <p class="section-sub">All times shown in your local timezone. 45 minutes is usually enough to know if there's a fit.</p>
    <!-- Google Calendar Appointment Scheduling begin -->
    <div class="calendar-wrap">
      <iframe src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ1WUIRsRks4hxf6-nWhuq942Xpp7WNKM1rKJHUqthdkdPUKyq7QICNNAZ-F72XLef1Pj_h3FSVu?gv=true" class="calendar-iframe" loading="lazy"></iframe>
    </div>
    <!-- end Google Calendar Appointment Scheduling -->
  </SectionWrapper>

  <TextSection title="Prefer email?" bg="white">
    <p>Write to <a href="mailto:hello@nimzodata.com" class="email-link">hello@nimzodata.com</a>. We reply within one business day, usually the same day. Tell us about your current stack and what's not working — the more concrete, the faster the first call will be.</p>
  </TextSection>

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What happens after you reach out.</h2>
    <ProcessSteps
      steps={[
        { icon: 'mail', title: "Book a call or email us", description: "Use the calendar above. Or email us if you'd rather write first." },
        { icon: 'clipboard-list', title: "Quick questionnaire", description: "We send a short form (5 min to fill) — your stack, the main problem, your timeline. Makes the call count." },
        { icon: 'video', title: "The discovery call", description: "45-minute conversation. We listen, ask questions, tell you honestly whether we're a fit." },
        { icon: 'file-text', title: "The proposal", description: "Within 5 business days if there's a fit. If scope isn't clear yet, we propose a paid 1–2 week audit that produces a fixed-price build proposal. If scope is already clear, we send a fixed-price proposal directly." },
      ]}
    />
  </SectionWrapper>

  <TextSection title="Where we are." bg="white">
    <p>Based in France. Working remotely across Europe, with occasional on-site visits for kickoffs or hands-on workshops on larger engagements.</p>
  </TextSection>

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Not ready to talk?</h2>
    <div class="cta-cards-grid">
      <CTACard
        title="See our services"
        description="See how we can help — scope, timeline, and pricing for each engagement."
        href="/"
        buttonText="Browse services"
        dataTrack="contact-cta-services"
        variant="link"
      />
      <CTACard
        title="Browse the stack"
        description="Every tool we work with and our honest opinion on when to use it."
        href="/technologies/"
        buttonText="See technologies"
        dataTrack="contact-cta-tech"
        variant="link"
      />
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 32px 0;
    line-height: 1.25;
  }

  .section-heading--with-sub {
    margin-bottom: 12px;
  }

  .section-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0 0 32px 0;
    line-height: 1.6;
  }

  .email-link {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .email-link:hover { opacity: 0.75; }

  .calendar-wrap {
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .calendar-iframe {
    display: block;
    width: 100%;
    border: 0;
    height: 900px;
  }

  @media (max-width: 767px) {
    .calendar-iframe {
      height: 1600px;
    }
  }

  .cta-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .cta-cards-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
</style>
