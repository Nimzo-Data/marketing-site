---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroStandard from '../components/heroes/HeroStandard.astro';
import TextSection from '../components/content/TextSection.astro';
import ProcessSteps from '../components/content/ProcessSteps.astro';
import CalendlyEmbed from '../components/integrations/CalendlyEmbed.astro';
import CTACard from '../components/cards/CTACard.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
---

<BaseLayout
  title="Contact | Nimzo Data"
  description="30-minute call about your data stack. No sales pitch. We tell you honestly whether we're a fit. hello@nimzodata.com."
>
  <link
    slot="head"
    rel="stylesheet"
    href="https://assets.calendly.com/assets/external/widget.css"
  />

  <HeroStandard
    title="Let's talk about your data stack."
    subtitle="30-minute call. We ask about your current setup, what isn't working, and what you want to achieve. No sales pitch — just an honest conversation about whether we're a good fit."
  />

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Pick a time that works.</h2>
    <p class="section-sub">All times shown in your local timezone. 30 minutes is usually enough to know if there's a fit.</p>
    <CalendlyEmbed url="https://calendly.com/nimzodata/free-call" minHeight="700px" />
  </SectionWrapper>

  <TextSection title="Prefer email?" bg="white">
    <p>Write to <a href="mailto:hello@nimzodata.com" class="email-link">hello@nimzodata.com</a>. We reply within one business day, usually the same day. Tell us about your current stack and what's not working — the more concrete, the faster the first call will be.</p>
  </TextSection>

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">What happens after you reach out.</h2>
    <ProcessSteps
      steps={[
        { number: 1, title: "Brief overview", description: "We ask for a quick summary of your data stack and main challenge — one email, five minutes to write." },
        { number: 2, title: "Discovery call", description: "We schedule a 30-minute conversation within the week." },
        { number: 3, title: "Fixed-price proposal", description: "If there's a fit, we send a scoping questionnaire and a fixed-price proposal within 5 business days." },
      ]}
    />
  </SectionWrapper>

  <TextSection title="Where we are." bg="white">
    <p>Based in France. Working remotely across Europe, with occasional on-site visits for kickoffs or hands-on workshops on larger engagements.</p>
  </TextSection>

  <SectionWrapper py="lg" bg="white">
    <h2 class="section-heading">Not ready to talk?</h2>
    <div class="cta-cards-grid">
      <CTACard
        title="See our services"
        description="Browse service pages for scope, timeline, and pricing on each engagement type."
        href="/"
        buttonText="Browse services"
        dataTrack="contact-cta-services"
      />
      <CTACard
        title="Browse the stack"
        description="Every tool we work with and our honest opinion on when to use it."
        href="/technologies/"
        buttonText="See technologies"
        dataTrack="contact-cta-tech"
      />
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 8px 0;
    line-height: 1.25;
  }

  .section-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0 0 32px 0;
    line-height: 1.6;
  }

  .email-link {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .email-link:hover { opacity: 0.75; }

  .cta-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .cta-cards-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
</style>
